// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String       @id @default(uuid())
  firstName   String
  lastName    String
  username    String       @unique
  email       String       @unique
  password    String
  role        String       @default("HAUSBESITZER") // HAUSBESITZER or PROFESSIONIST
  property    Property?
  contractors Contractor[]
  homes       UserHome[]
  projects    Project[]
  chatMessages ChatMessage[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model UserHome {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  addressId   String?
  address     Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([addressId])
}

model Address {
  id                    String     @id @default(uuid())
  street                String
  houseNumber           String?
  postalCode            String
  city                  String
  country               String     @default("AT")
  cadastralMunicipality String?
  plotNumber            String?
  homes                 UserHome[]
  documents             Document[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model Money {
  id        String     @id @default(uuid())
  amount    Decimal
  currency  String     @default("EUR")
  label     String?
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model ProjectStatus {
  code      String   @id
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Property {
  id                    String            @id @default(uuid())
  userId                String            @unique
  user                  User              @relation(fields: [userId], references: [id])
  address               String
  plotArea              Float
  livingArea            Float
  usableArea            Float
  constructionYear      Int
  plotNumber            String?
  cadastralMunicipality String?
  rooms                 Room[]
  municipalTaxes        MunicipalTax[]
  reminders             Reminder[]
  documents             Document[]
  projects              Project[]
  insurancePolicies     InsurancePolicy[]
  insuranceClaims       InsuranceClaim[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model Room {
  id            String   @id @default(uuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name          String
  type          String?
  area          Float
  floorCovering String
  wallFinish    String
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Reminder {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  title      String
  dueDate    DateTime
  remindAt   DateTime
  status     String   @default("OPEN")
  sourceType String?
  sourceId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  municipalTax MunicipalTax?
}

model Document {
  id           String   @id @default(uuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  dataUrl      String
  documentType String
  title        String?
  fileSize     Int?
  url          String?
  addressId    String?
  address      Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)
  moneyId      String?
  money        Money?   @relation(fields: [moneyId], references: [id], onDelete: SetNull)
  sourceType   String?
  sourceId     String?
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  municipalTaxes MunicipalTax[]

  @@index([projectId])
}

model MunicipalTax {
  id         String    @id @default(uuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type       String
  amount     Float
  interval   String
  dueDate    DateTime
  notes      String?
  reminderId String?   @unique
  reminder   Reminder? @relation(fields: [reminderId], references: [id], onDelete: SetNull)
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model InsurancePolicy {
  id            String   @id @default(uuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  provider      String
  policyNumber  String
  hotline       String?
  deductible    Float?
  pdfDocumentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([propertyId])
  @@index([provider])
}

model InsuranceClaim {
  id          String   @id @default(uuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  claimDate   DateTime
  type        String
  description String
  exportToken String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
  @@index([claimDate])
  @@index([type])
}

model Contractor {
  id            String             @id @default(uuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  trade         String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  experience    String?
  averageRating Float?
  ratingCount   Int?
  offers        Offer[]
  reviews       ContractorReview[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId])
  @@index([trade])
}

model Project {
  id                        String             @id @default(uuid())
  userId                    String
  user                      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId                String?
  property                  Property?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  title                     String
  category                  String             @default("Sanierung")
  trade                     String?
  description               String?
  targetBudget              Float              @default(0)
  desiredStartDate          DateTime?
  desiredDeadline           DateTime?
  status                    String             @default("IN_PLANUNG")
  documentReference         String?
  documents                 Document[]
  offers                    Offer[]
  reviews                   ContractorReview[]
  acceptedOfferId           String?
  orderConfirmationFileName String?
  orderConfirmationDataUrl  String?
  finalContractFileName     String?
  finalContractDataUrl      String?
  finalInvoiceAmount        Float?
  finalInvoiceFileName      String?
  finalInvoiceDataUrl       String?
  invoiceDeviationEuro      Float?
  invoiceDeviationPercent   Float?
  invoiceDeviationWarning   Boolean            @default(false)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@index([category])
  @@index([trade])
}

model Offer {
  id                String         @id @default(uuid())
  projectId         String
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractorId      String
  contractor        Contractor     @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  status            String         @default("PENDING")
  amount            Float
  currency          String         @default("EUR")
  validUntil        DateTime?
  scopeDescription  String         @default("")
  availabilityStart DateTime?
  durationDays      Int            @default(0)
  notes             String?
  pdfFileName       String?
  pdfMimeType       String?
  pdfDataUrl        String?
  services          OfferService[]
  negotiation       NegotiationSession?
  chatThread        ChatThread?
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([projectId])
  @@index([contractorId])
  @@index([status])
  @@unique([projectId, contractorId])
}

model ChatThread {
  id        String        @id @default(uuid())
  offerId   String        @unique
  offer     Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        String     @id @default(uuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime   @default(now())

  @@index([threadId])
  @@index([senderId])
}

model NegotiationSession {
  id                      String               @id @default(uuid())
  offerId                 String               @unique
  offer                   Offer                @relation(fields: [offerId], references: [id], onDelete: Cascade)
  status                  String               @default("DRAFT")
  customerTargetPrice     Float?
  customerMaxPrice        Float?
  contractorTargetPrice   Float?
  contractorMinPrice      Float?
  finalProposalAmount     Float?
  customerConfirmedAt     DateTime?
  contractorConfirmedAt   DateTime?
  messages                NegotiationMessage[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([status])
}

model NegotiationMessage {
  id            String             @id @default(uuid())
  sessionId     String
  session       NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role          String
  text          String
  priceProposal Float?
  round         Int                @default(1)
  metadata      String?
  createdAt     DateTime           @default(now())

  @@index([sessionId])
  @@index([role])
}

model OfferService {
  id          String   @id @default(uuid())
  offerId     String
  offer       Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  type        String
  description String
  createdAt   DateTime @default(now())

  @@index([offerId])
  @@index([type])
}

model ContractorReview {
  id            String     @id @default(uuid())
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractorId  String
  contractor    Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  priceFaithful Int
  punctuality   Int
  speed         Int
  quality       Int
  average       Float
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([projectId, contractorId])
  @@index([contractorId])
}
